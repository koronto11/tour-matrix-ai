[Unit]
Description=Tour Matrix AI Server
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/var/www/tour-matrix-ai/server
ExecStart=/usr/bin/node /var/www/tour-matrix-ai/server/index.js
Restart=always
RestartSec=5
Environment=NODE_ENV=production

[Install]
WantedBy=multi-user.target